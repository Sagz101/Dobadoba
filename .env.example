# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# MAPLIBRE_API_KEY: Key for MapLibre/Mapbox tiles
MAPLIBRE_API_KEY=MAPLIBRE_API_KEY_PLACEHOLDER

# SMS_GATEWAY_API_KEY: API key for Airtel/TNM dual failover SMS gateway
SMS_GATEWAY_API_KEY=SMS_GATEWAY_API_KEY_PLACEHOLDER

# AIRTEL_SMS_API_KEY: Dedicated Airtel Malawi SMS Gateway Token
AIRTEL_SMS_API_KEY=Bearer_AirtelLiveApiKeyProdTokenPlaceholder

# AIRTEL_SMS_CLIENT_ID: Dedicated Airtel Malawi API Client Identifier
AIRTEL_SMS_CLIENT_ID=airtel_malawi_client_id_here

# TNM_SMS_API_KEY: Dedicated TNM Malawi SMS Gateway Token
TNM_SMS_API_KEY=Bearer_TnmLiveApiKeyProdTokenPlaceholder

# TNM_SMS_CLIENT_ID: Dedicated TNM Malawi API Client Identifier
TNM_SMS_CLIENT_ID=tnm_malawi_client_id_here

# WALLET_API_KEY: Payment/digital wallet processing key
WALLET_API_KEY=WALLET_API_KEY_PLACEHOLDER

# DOBA_PRIMARY_PIN: Active SHA256 SSL pin for api.dobadoba.mw
DOBA_PRIMARY_PIN=sha256/DobaPrimaryPinGenSha256HashCheckValue=

# DOBA_BACKUP_PIN: Backup SHA256 SSL pin for api.dobadoba.mw
DOBA_BACKUP_PIN=sha256/DobaBackupPinGenSha256HashBackupValue=
